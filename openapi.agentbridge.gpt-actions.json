{
  "openapi": "3.1.0",
  "info": {
    "title": "AgentBridge GPT Actions Project Inspector",
    "version": "0.5.0-delta",
    "description": "GPT Actions compatible OpenAPI schema for AgentBridge Project Inspector and safe project browser JSON endpoints. This is not MCP and does not define a /mcp endpoint."
  },
  "servers": [
    {
      "url": "https://YOUR-TUNNEL-URL.example",
      "description": "Replace with the current HTTPS tunnel URL for your local AgentBridge daemon."
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/chatgpt/projects": {
      "get": {
        "operationId": "listProjects",
        "summary": "List AgentBridge projects",
        "description": "List registered CodexLink projects for the project picker. Returns registry mode, branch, status, root hints, and fallback current project when no registry exists.",
        "responses": {
          "200": {
            "description": "Project list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "ok",
                    "mode",
                    "projects"
                  ],
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "mode": {
                      "type": "string",
                      "enum": [
                        "registry",
                        "current_project_fallback"
                      ]
                    },
                    "projects": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "root_hint": {
                            "type": "string"
                          },
                          "registered": {
                            "type": "boolean"
                          },
                          "git_available": {
                            "type": "boolean"
                          },
                          "branch": {
                            "type": "string"
                          },
                          "clean": {
                            "type": "boolean"
                          },
                          "last_seen": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      }
                    }
                  },
                  "additionalProperties": true
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token"
          }
        }
      }
    },
    "/chatgpt/active-project": {
      "get": {
        "operationId": "getActiveProject",
        "summary": "Get active project",
        "description": "Return the active selected CodexLink project. If none is selected, call listProjects and ask the user to choose.",
        "responses": {
          "200": {
            "description": "Get active project",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "ok"
                  ],
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "active_project": {
                      "type": [
                        "object",
                        "null"
                      ],
                      "additionalProperties": true
                    },
                    "next_action": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": true
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token"
          }
        }
      }
    },
    "/chatgpt/projects/{projectId}/tree": {
      "get": {
        "operationId": "getProjectTree",
        "summary": "Get project tree",
        "description": "Return a safe project tree plus awareness metadata: inventory, classification, important files, recommended reads, suspicious files, and coverage warnings.",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Safe projectId returned by listProjects. Raw filesystem paths are not accepted.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "max_depth",
            "in": "query",
            "required": false,
            "description": "Maximum traversal depth.",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 20
            }
          },
          {
            "name": "max_entries",
            "in": "query",
            "required": false,
            "description": "Maximum entries returned.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5000
            }
          },
          {
            "name": "include_hidden",
            "in": "query",
            "required": false,
            "description": "Include hidden files except blocked secrets.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "include_sizes",
            "in": "query",
            "required": false,
            "description": "Include file sizes.",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Get project tree",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "ok"
                  ],
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "project_id": {
                      "type": "string"
                    },
                    "root_hint": {
                      "type": "string"
                    },
                    "max_depth": {
                      "type": "integer"
                    },
                    "max_entries": {
                      "type": "integer"
                    },
                    "total_files": {
                      "type": "integer"
                    },
                    "total_folders": {
                      "type": "integer"
                    },
                    "returned_entries": {
                      "type": "integer"
                    },
                    "truncated": {
                      "type": "boolean"
                    },
                    "ignored_dirs": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "entries": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "inventory": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "classification": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "important_candidates": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "recommended_next_reads": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "suspicious_root_files": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "coverage_warning": {
                      "type": [
                        "object",
                        "null"
                      ],
                      "additionalProperties": true
                    },
                    "recommended_next_action": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  },
                  "additionalProperties": true
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token"
          },
          "404": {
            "description": "Project not found or path not available"
          }
        }
      }
    },
    "/chatgpt/projects/{projectId}/files/search": {
      "get": {
        "operationId": "searchProjectFiles",
        "summary": "Search project files",
        "description": "Search file names and project-relative paths in one CodexLink project. Use projectId from listProjects. Does not read file contents.",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Safe projectId returned by listProjects. Raw filesystem paths are not accepted.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "File name or project-relative path query.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "max_results",
            "in": "query",
            "required": false,
            "description": "Maximum matches returned.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500
            }
          },
          {
            "name": "max_depth",
            "in": "query",
            "required": false,
            "description": "Maximum traversal depth.",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 20
            }
          },
          {
            "name": "case_sensitive",
            "in": "query",
            "required": false,
            "description": "Use case-sensitive matching.",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search project files",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "ok"
                  ],
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "project_id": {
                      "type": "string"
                    },
                    "query": {
                      "type": "string"
                    },
                    "matches": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "truncated": {
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": true
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token"
          },
          "404": {
            "description": "Project not found or path not available"
          }
        }
      }
    },
    "/chatgpt/projects/{projectId}/file": {
      "get": {
        "operationId": "readProjectFile",
        "summary": "Read project file",
        "description": "Read one safe text file by project-relative path. Blocks unsafe paths/secrets/binary files and returns read_status plus coverage warning when partial.",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Safe projectId returned by listProjects. Raw filesystem paths are not accepted.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "path",
            "in": "query",
            "required": true,
            "description": "Project-relative path. Cannot be absolute or traversal.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "max_chars",
            "in": "query",
            "required": false,
            "description": "Maximum returned content characters.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50000
            }
          },
          {
            "name": "start_line",
            "in": "query",
            "required": false,
            "description": "Optional 1-based start line.",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "num_lines",
            "in": "query",
            "required": false,
            "description": "Optional number of lines.",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Read project file",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "ok"
                  ],
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "project_id": {
                      "type": "string"
                    },
                    "path": {
                      "type": "string"
                    },
                    "size": {
                      "type": "integer"
                    },
                    "encoding": {
                      "type": "string"
                    },
                    "truncated": {
                      "type": "boolean"
                    },
                    "read_status": {
                      "type": "string"
                    },
                    "line_count": {
                      "type": "integer"
                    },
                    "line_count_estimate": {
                      "type": "integer"
                    },
                    "line_range_returned": {
                      "type": [
                        "array",
                        "null"
                      ],
                      "items": {
                        "type": "integer"
                      }
                    },
                    "bytes_returned": {
                      "type": "integer"
                    },
                    "coverage_warning": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "redacted": {
                      "type": "boolean"
                    },
                    "content": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": true
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token"
          },
          "404": {
            "description": "Project not found or path not available"
          }
        }
      }
    },
    "/chatgpt/projects/{projectId}/grep": {
      "get": {
        "operationId": "searchProjectText",
        "summary": "Search project text",
        "description": "Search text inside safe project files. Use projectId from listProjects. Returns redacted snippets and skips ignored, secret, binary, and large files.",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Safe projectId returned by listProjects. Raw filesystem paths are not accepted.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Text query to search for.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "max_matches",
            "in": "query",
            "required": false,
            "description": "Maximum matches returned.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500
            }
          },
          {
            "name": "max_file_size",
            "in": "query",
            "required": false,
            "description": "Maximum file size to search.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000000
            }
          },
          {
            "name": "max_depth",
            "in": "query",
            "required": false,
            "description": "Maximum traversal depth.",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 20
            }
          },
          {
            "name": "case_sensitive",
            "in": "query",
            "required": false,
            "description": "Use case-sensitive matching.",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search project text",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "ok"
                  ],
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "project_id": {
                      "type": "string"
                    },
                    "query": {
                      "type": "string"
                    },
                    "matches": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "truncated": {
                      "type": "boolean"
                    },
                    "redacted": {
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": true
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token"
          },
          "404": {
            "description": "Project not found or path not available"
          }
        }
      }
    },
    "/chatgpt/projects/{projectId}/select": {
      "post": {
        "operationId": "selectProject",
        "summary": "Select active project",
        "description": "Select one registered CodexLink project as active. Use projectId from listProjects. Stores local metadata only and does not execute code.",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Safe projectId returned by listProjects. Raw filesystem paths are not accepted.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Select active project",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "ok"
                  ],
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "active_project": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  },
                  "additionalProperties": true
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token"
          },
          "404": {
            "description": "Project not found or path not available"
          }
        }
      }
    },
    "/chatgpt/projects/{projectId}/inspect": {
      "get": {
        "operationId": "inspectProject",
        "summary": "Inspect one AgentBridge project",
        "description": "Inspect one CodexLink project by safe projectId from listProjects. Returns repo state, changed files, commits, tags, session state, tests, and safety flags.",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Safe AgentBridge project ID returned by listProjects. Raw filesystem paths are not accepted.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "required": false,
            "description": "Inspection detail level.",
            "schema": {
              "type": "string",
              "enum": [
                "summary",
                "standard",
                "deep",
                "full"
              ]
            }
          },
          {
            "name": "max_chars",
            "in": "query",
            "required": false,
            "description": "Maximum characters per large text field. Server accepts 200 to 50000.",
            "schema": {
              "type": "integer",
              "minimum": 200,
              "maximum": 50000
            }
          },
          {
            "name": "include_diff",
            "in": "query",
            "required": false,
            "description": "Whether to include fuller diff context when supported by the inspector.",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project inspector snapshot",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "ok",
                    "project",
                    "repo",
                    "agentbridge",
                    "codex",
                    "tests",
                    "safety",
                    "limits"
                  ],
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "project": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "repo": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "agentbridge": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "codex": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "tests": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "safety": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "limits": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  },
                  "additionalProperties": true
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token"
          },
          "404": {
            "description": "Project ID is not registered or available as the default current project"
          }
        }
      }
    },
    "/chatgpt/projects/{projectId}/codex-changes": {
      "get": {
        "operationId": "getCodexChanges",
        "summary": "Get Codex changes for one project",
        "description": "Get Codex change summary for one registered project. Use projectId from listProjects. Returns changed files, diff summary, and related project context.",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Safe AgentBridge project ID returned by listProjects. Raw filesystem paths are not accepted.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "required": false,
            "description": "Inspection detail level.",
            "schema": {
              "type": "string",
              "enum": [
                "summary",
                "standard",
                "deep",
                "full"
              ]
            }
          },
          {
            "name": "max_chars",
            "in": "query",
            "required": false,
            "description": "Maximum characters per large text field. Server accepts 200 to 50000.",
            "schema": {
              "type": "integer",
              "minimum": 200,
              "maximum": 50000
            }
          },
          {
            "name": "include_diff",
            "in": "query",
            "required": false,
            "description": "Whether to include fuller diff context when supported by the inspector.",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Codex changes summary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "ok",
                    "project_id",
                    "changed_files",
                    "codex_progress",
                    "codex_result",
                    "limits"
                  ],
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "project_id": {
                      "type": "string"
                    },
                    "branch": {
                      "type": "string"
                    },
                    "clean": {
                      "type": "boolean"
                    },
                    "changed_files": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "diff_summary": {
                      "type": "string"
                    },
                    "codex_progress": {
                      "type": "string"
                    },
                    "codex_result": {
                      "type": "string"
                    },
                    "limits": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  },
                  "additionalProperties": true
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token"
          },
          "404": {
            "description": "Project ID is not registered or available as the default current project"
          }
        }
      }
    },
    "/chatgpt/projects/{projectId}/review-packet": {
      "get": {
        "operationId": "getReviewPacket",
        "summary": "Get a ChatGPT review packet for one project",
        "description": "Get a technical review packet for one registered project. Includes repo status, Codex progress, tests, safety risks, and recommended next steps.",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Safe AgentBridge project ID returned by listProjects. Raw filesystem paths are not accepted.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "required": false,
            "description": "Inspection detail level.",
            "schema": {
              "type": "string",
              "enum": [
                "summary",
                "standard",
                "deep",
                "full"
              ]
            }
          },
          {
            "name": "max_chars",
            "in": "query",
            "required": false,
            "description": "Maximum characters per large text field. Server accepts 200 to 50000.",
            "schema": {
              "type": "integer",
              "minimum": 200,
              "maximum": 50000
            }
          },
          {
            "name": "include_diff",
            "in": "query",
            "required": false,
            "description": "Whether to include fuller diff context when supported by the inspector.",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Review packet summary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "ok",
                    "project_id",
                    "review_packet",
                    "limits"
                  ],
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "project_id": {
                      "type": "string"
                    },
                    "review_packet": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "limits": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  },
                  "additionalProperties": true
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token"
          },
          "404": {
            "description": "Project ID is not registered or available as the default current project"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "AgentBridge local token",
        "description": "Use the local AgentBridge bearer token. Do not publish, commit, or paste the token into this schema."
      }
    }
  }
}
