{
  "openapi": "3.1.0",
  "info": {
    "title": "AgentBridge ChatGPT Tool Adapter",
    "version": "0.4.0-gamma",
    "description": "OpenAPI adapter for AgentBridge Project Inspector JSON endpoints. This is not MCP and does not define a /mcp endpoint."
  },
  "servers": [
    {
      "url": "https://YOUR-TUNNEL-URL.example",
      "description": "Replace with the HTTPS tunnel URL registered for your local AgentBridge daemon."
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/chatgpt/projects": {
      "get": {
        "operationId": "listProjects",
        "summary": "List AgentBridge projects available to the local bridge",
        "description": "Returns registered projects, or the current local project when no registry entries exist.",
        "responses": {
          "200": {
            "description": "Project list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectListResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/chatgpt/projects/{projectId}/inspect": {
      "get": {
        "operationId": "inspectProject",
        "summary": "Inspect one AgentBridge project",
        "description": "Returns a redacted Project Inspector snapshot for a registered project ID, or for the current default project when no registry exists.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          },
          {
            "$ref": "#/components/parameters/Mode"
          },
          {
            "$ref": "#/components/parameters/MaxChars"
          },
          {
            "$ref": "#/components/parameters/IncludeDiff"
          }
        ],
        "responses": {
          "200": {
            "description": "Project inspector snapshot",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InspectorSnapshot"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/ProjectNotFound"
          }
        }
      }
    },
    "/chatgpt/projects/{projectId}/codex-changes": {
      "get": {
        "operationId": "getCodexChanges",
        "summary": "Get Codex changes for one project",
        "description": "Returns changed file summaries, diff summary, Codex progress, and Codex result text after AgentBridge redaction and truncation.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          },
          {
            "$ref": "#/components/parameters/Mode"
          },
          {
            "$ref": "#/components/parameters/MaxChars"
          },
          {
            "$ref": "#/components/parameters/IncludeDiff"
          }
        ],
        "responses": {
          "200": {
            "description": "Codex changes summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CodexChangesResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/ProjectNotFound"
          }
        }
      }
    },
    "/chatgpt/projects/{projectId}/review-packet": {
      "get": {
        "operationId": "getReviewPacket",
        "summary": "Get a ChatGPT review packet for one project",
        "description": "Returns a redacted review packet derived from the Project Inspector snapshot.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          },
          {
            "$ref": "#/components/parameters/Mode"
          },
          {
            "$ref": "#/components/parameters/MaxChars"
          },
          {
            "$ref": "#/components/parameters/IncludeDiff"
          }
        ],
        "responses": {
          "200": {
            "description": "Review packet summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReviewPacketResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/ProjectNotFound"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Use the local AgentBridge bearer token. Do not publish, commit, or paste the token into this spec."
      }
    },
    "parameters": {
      "ProjectId": {
        "name": "projectId",
        "in": "path",
        "required": true,
        "description": "Safe AgentBridge project ID returned by listProjects. Raw filesystem paths are not accepted.",
        "schema": {
          "type": "string"
        }
      },
      "Mode": {
        "name": "mode",
        "in": "query",
        "required": false,
        "description": "Inspection detail level.",
        "schema": {
          "type": "string",
          "enum": [
            "summary",
            "standard",
            "deep",
            "full"
          ]
        }
      },
      "MaxChars": {
        "name": "max_chars",
        "in": "query",
        "required": false,
        "description": "Maximum characters per large text field. Server currently accepts 200 to 50000.",
        "schema": {
          "type": "integer",
          "minimum": 200,
          "maximum": 50000
        }
      },
      "IncludeDiff": {
        "name": "include_diff",
        "in": "query",
        "required": false,
        "description": "Whether to include fuller diff context when supported by the inspector.",
        "schema": {
          "type": "boolean"
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid bearer token",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "ProjectNotFound": {
        "description": "Project ID is not registered or available as the default current project",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": [
          "ok",
          "error"
        ],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": false
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      },
      "ProjectListResponse": {
        "type": "object",
        "required": [
          "ok",
          "projects"
        ],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "projects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProjectListItem"
            }
          }
        },
        "additionalProperties": true
      },
      "ProjectListItem": {
        "type": "object",
        "required": [
          "id",
          "name",
          "root_hint",
          "registered"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "root_hint": {
            "type": "string",
            "description": "Redacted local path hint."
          },
          "registered": {
            "type": "boolean"
          },
          "branch": {
            "type": "string"
          },
          "clean": {
            "type": "boolean"
          },
          "last_seen": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "InspectorSnapshot": {
        "type": "object",
        "required": [
          "ok",
          "project",
          "repo",
          "agentbridge",
          "codex",
          "tests",
          "safety",
          "limits"
        ],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "project": {
            "$ref": "#/components/schemas/ProjectInfo"
          },
          "repo": {
            "$ref": "#/components/schemas/RepoInfo"
          },
          "agentbridge": {
            "$ref": "#/components/schemas/AgentBridgeSessionSummary"
          },
          "codex": {
            "$ref": "#/components/schemas/CodexInspectorSummary"
          },
          "tests": {
            "$ref": "#/components/schemas/TestSummary"
          },
          "safety": {
            "$ref": "#/components/schemas/SafetySummary"
          },
          "limits": {
            "$ref": "#/components/schemas/InspectorLimits"
          }
        },
        "additionalProperties": true
      },
      "ProjectInfo": {
        "type": "object",
        "required": [
          "id",
          "name",
          "root_hint",
          "registered"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "root_hint": {
            "type": "string"
          },
          "registered": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      },
      "RepoInfo": {
        "type": "object",
        "properties": {
          "available": {
            "type": "boolean"
          },
          "branch": {
            "type": "string"
          },
          "clean": {
            "type": "boolean"
          },
          "status_short": {
            "type": "string"
          },
          "changed_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "changed_file_summary": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChangedFile"
            }
          },
          "diff_summary": {
            "type": "string"
          },
          "recent_commits": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recent_tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      },
      "ChangedFile": {
        "type": "object",
        "required": [
          "path",
          "status",
          "summary"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "AgentBridgeSessionSummary": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string"
          },
          "session_status": {
            "type": "string"
          },
          "user_goal": {
            "type": "string"
          },
          "next_action": {
            "type": "string"
          },
          "chatgpt_plan_status": {
            "type": "string"
          },
          "codex_task_status": {
            "type": "string"
          },
          "last_test_status": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "CodexInspectorSummary": {
        "type": "object",
        "properties": {
          "chatgpt_plan_summary": {
            "type": "string"
          },
          "progress_summary": {
            "type": "string"
          },
          "result_summary": {
            "type": "string"
          },
          "review_packet_summary": {
            "type": "string"
          },
          "changed_file_summary": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChangedFile"
            }
          }
        },
        "additionalProperties": true
      },
      "TestSummary": {
        "type": "object",
        "properties": {
          "latest_summary": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "SafetySummary": {
        "type": "object",
        "properties": {
          "pending_approvals": {
            "type": "integer"
          },
          "risk_flags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      },
      "InspectorLimits": {
        "type": "object",
        "properties": {
          "redacted": {
            "type": "boolean"
          },
          "truncated": {
            "type": "boolean"
          },
          "truncated_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "diff_truncated": {
            "type": "boolean"
          },
          "max_chars_per_field": {
            "type": "integer"
          }
        },
        "additionalProperties": true
      },
      "CodexChangesResponse": {
        "type": "object",
        "required": [
          "ok",
          "project_id",
          "changed_files",
          "codex_progress",
          "codex_result",
          "limits"
        ],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "project_id": {
            "type": "string"
          },
          "branch": {
            "type": "string"
          },
          "clean": {
            "type": "boolean"
          },
          "changed_files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChangedFile"
            }
          },
          "diff_summary": {
            "type": "string"
          },
          "codex_progress": {
            "type": "string"
          },
          "codex_result": {
            "type": "string"
          },
          "limits": {
            "$ref": "#/components/schemas/InspectorLimits"
          }
        },
        "additionalProperties": true
      },
      "ReviewPacketResponse": {
        "type": "object",
        "required": [
          "ok",
          "project_id",
          "review_packet",
          "limits"
        ],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "project_id": {
            "type": "string"
          },
          "review_packet": {
            "type": "object",
            "properties": {
              "summary": {
                "type": "string"
              },
              "files_changed": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ChangedFile"
                }
              },
              "tests": {
                "type": "string"
              },
              "risks": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "questions_for_chatgpt": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          },
          "limits": {
            "$ref": "#/components/schemas/InspectorLimits"
          }
        },
        "additionalProperties": true
      }
    }
  }
}
