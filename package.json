{
  "name": "agentbridge",
  "version": "1.0.0",
  "description": "Local shared-session bridge for ChatGPT and Codex.",
  "type": "module",
  "bin": {
    "agentbridge": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "setup-codexlink-first-time.bat",
    "run-gpt-action-setup.bat",
    "restore-ngrok-setup.bat",
    "start-codexlink.bat",
    "stop-codexlink.bat",
    "docs/architecture",
    "docs/gpt",
    "docs/guides",
    "docs/specs",
    "plugins",
    ".agents",
    "scripts/generate-openapi.mjs",
    "scripts/prepare-gpt-action.ps1",
    "scripts/start-codexlink.ps1",
    "scripts/stop-codexlink.ps1",
    "openapi.agentbridge.json",
    "openapi.agentbridge.gpt-actions.json",
    "openapi.codexlink.relay.gpt-actions.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate:openapi": "node scripts/generate-openapi.mjs",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "agentbridge",
    "codex",
    "chatgpt",
    "mcp",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.2",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "overrides": {
    "hono": "4.12.26",
    "vite": "8.0.16"
  }
}
